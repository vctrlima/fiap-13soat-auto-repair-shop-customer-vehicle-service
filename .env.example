# Server
SERVER_PORT=3001
SERVER_HOST=http://localhost:3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/customer_vehicle_db?connection_limit=5

# CORS (optional — defaults to '*')
CORS_ORIGIN=

# Auth (REQUIRED)
JWT_ACCESS_TOKEN_SECRET=change-me-to-a-secure-random-value
JWT_REFRESH_TOKEN_SECRET=change-me-to-a-secure-random-value

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info
